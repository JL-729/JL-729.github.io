{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jl729",
  "compatibility_date": "2024-04-05",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "vars": {
    "WEBDAV_URL": "YOUR_WEBDAV_URL",
    "WEBDAV_USER": "YOUR_WEBDAV_USER",
    "WEBDAV_PASS": "YOUR_WEBDAV_PASS",
    "JWT_SECRET": "YOUR_JWT_SECRET"
  }
}
